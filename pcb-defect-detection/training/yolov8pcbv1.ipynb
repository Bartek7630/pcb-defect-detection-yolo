import os
from ultralytics import YOLO

dataset_dir = 'PCB Defects.v6i.yolov8' 
yaml_path = os.path.join(dataset_dir, 'data.yaml')

if __name__ == "__main__":
    if not os.path.exists(yaml_path):
        print("Brak pliku data.yaml")
    else:
        model = YOLO("yolov8n.pt")
        results = model.train(
            data=yaml_path,
            epochs=50,
            batch=32,
            imgsz=640,
            device='cuda', 
            project='pcb_local_results',
            name='yolov8_pcb_rtx',
            workers=2,
            cache=True
        )